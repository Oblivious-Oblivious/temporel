{
  "$schema": "https://raw.githubusercontent.com/Oblivious-Oblivious/Emeralds/master/schema/em.schema.json",
  "author": "",
  "name": "temporel",
  "version": "0.0.1",
  "license": "gpl-v3",
  "locignore": {
    "extensions": [],
    "directories": ["libs"]
  },
  "lintignore": {
    "extensions": [],
    "directories": ["libs"]
  },
  "scripts": {},
  "compile-flags": {
    "darwin": {
      "cc": "clang",
      "debug": {
        "opt": "-O2",
        "version": "-std=c89",
        "flags": "-g -fsanitize=address",
        "warnings": "-Wall -Wextra -Werror -pedantic -pedantic-errors -Wpedantic",
        "libs": ""
      },
      "release": {
        "opt": "-O2",
        "version": "-std=c89",
        "flags": "",
        "warnings": "",
        "libs": ""
      }
    },
    "linux": {
      "cc": "gcc",
      "debug": {
        "opt": "-O2",
        "version": "-std=c89",
        "flags": "-g",
        "warnings": "-Wall -Wextra -Werror -pedantic -pedantic-errors -Wpedantic",
        "libs": ""
      },
      "release": {
        "opt": "-O2",
        "version": "-std=c89",
        "flags": "",
        "warnings": "",
        "libs": ""
      }
    },
    "win32": {
      "cc": "gcc",
      "debug": {
        "opt": "-O2",
        "version": "-std=c89",
        "flags": "-g",
        "warnings": "-Wall -Wextra -Werror -pedantic -pedantic-errors -Wpedantic",
        "libs": ""
      },
      "release": {
        "opt": "-O2",
        "version": "-std=c89",
        "flags": "",
        "warnings": "",
        "libs": ""
      }
    }
  },
  "dependencies": {},
  "dev-dependencies": {
    "cSpec": "Oblivious-Oblivious/cSpec"
  }
}
